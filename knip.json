{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "ignore": ["mailhog-oauth-wrapper/**"],
  "workspaces": {
    "backend": {
      "project": ["src/**/*.ts"],
      "entry": ["src/scripts/seedPlatformAdmin.ts"]
