{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "ignore": ["mailhog-oauth-wrapper/**"],
  "workspaces": {
    "backend": {
      "project": ["src/**/*.ts"],
      "entry": ["src/scripts/seedPlatformAdmin.ts"],
      "ignoreBinaries": [],
      "ignore": [
        "src/parser/invoiceParser.ts",
        "src/services/extraction/extractionLearningStore.ts",
        "src/services/extraction/vendorTemplateStore.ts"
      ]
    },
    "frontend": {
      "project": ["src/**/*.ts", "src/**/*.tsx"],
      "ignoreDependencies": ["jsdom", "@testing-library/jest-dom", "jest-environment-jsdom"]
    }
  }
}
