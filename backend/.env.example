ENV=local
# Supported values: local | stg | prod
NODE_ENV=development
PORT=4100
API_BASE_URL=http://localhost:4100
MONGO_URI=mongodb://ledgerbuddy_app:ledgerbuddy_local_pass@localhost:27018/ledgerbuddy?authSource=ledgerbuddy
APP_MANIFEST_PATH=
FRONTEND_BASE_URL=http://localhost:5177

OIDC_CLIENT_ID=ledgerbuddy-app
OIDC_CLIENT_SECRET=ledgerbuddy-local-secret
OIDC_SCOPES=openid profile email offline_access
OIDC_REDIRECT_URI=http://localhost:4100/api/auth/callback
OIDC_AUTH_URL=http://localhost:8280/realms/ledgerbuddy/protocol/openid-connect/auth
OIDC_TOKEN_URL=http://keycloak:8080/realms/ledgerbuddy/protocol/openid-connect/token
OIDC_VALIDATE_URL=http://keycloak:8080/realms/ledgerbuddy/protocol/openid-connect/token/introspect
OIDC_USERINFO_URL=http://keycloak:8080/realms/ledgerbuddy/protocol/openid-connect/userinfo
KEYCLOAK_INTERNAL_BASE_URL=http://keycloak:8080
KEYCLOAK_REALM=ledgerbuddy
AUTH_STATE_TTL_SECONDS=600
APP_SESSION_SIGNING_SECRET=local-dev-session-signing-secret-change-me
APP_SESSION_TTL_SECONDS=28800
REFRESH_TOKEN_ENCRYPTION_SECRET=local-dev-refresh-token-secret-32-chars
AUTH_AUTO_PROVISION_USERS=false
PLATFORM_ADMIN_EMAILS=platform-admin@local.test
PLATFORM_ADMIN_SEED_PASSWORD=
LOCAL_DEMO_SEED=false
LOCAL_DEMO_CONFIG_PATH=config/local-demo-users.json

INGESTION_SOURCES=email
INGESTION_CONCURRENCY=20
DEFAULT_USER_ID=local-user
DEFAULT_TENANT_ID=default
DEFAULT_WORKLOAD_TIER=standard

EMAIL_SOURCE_KEY=inbox-main
EMAIL_HOST=localhost
EMAIL_PORT=1143
EMAIL_SECURE=false
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_TRANSPORT=imap
EMAIL_MAILHOG_API_BASE_URL=http://localhost:8126
EMAIL_SMTP_HOST=localhost
EMAIL_SMTP_PORT=1125
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_TIMEOUT_MS=15000
EMAIL_AUTH_MODE=password
EMAIL_OAUTH_CLIENT_ID=
EMAIL_OAUTH_CLIENT_SECRET=
EMAIL_OAUTH_REFRESH_TOKEN=
EMAIL_OAUTH_ACCESS_TOKEN=
EMAIL_OAUTH_TOKEN_ENDPOINT=http://keycloak:8080/realms/ledgerbuddy/protocol/openid-connect/token
EMAIL_SIMULATION_SAMPLE_DIR=./sample-invoices/inbox
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REDIRECT_URI=http://localhost:4100/api/connect/gmail/callback
GMAIL_OAUTH_AUTH_URL=https://accounts.google.com/o/oauth2/v2/auth
GMAIL_OAUTH_TOKEN_URL=https://oauth2.googleapis.com/token
GMAIL_OAUTH_USERINFO_URL=https://www.googleapis.com/oauth2/v3/userinfo
GMAIL_OAUTH_SCOPES=https://mail.google.com/ openid email profile
GMAIL_OAUTH_STATE_TTL_SECONDS=600
GMAIL_OAUTH_HTTP_TIMEOUT_MS=15000
GMAIL_OAUTH_TOKEN_ENCRYPTION_SECRET=local-dev-gmail-oauth-encryption-secret
GMAIL_OAUTH_SUCCESS_REDIRECT_URL=http://localhost:5177
GMAIL_OAUTH_FAILURE_REDIRECT_URL=http://localhost:5177
EMAIL_MAILBOX=INBOX
EMAIL_FROM_FILTER=

# OCR provider behavior:
# - OCR_PROVIDER=llamaparse (DEFAULT) uses LlamaParse cloud OCR. Requires
#   LLAMA_CLOUD_API_KEY; the backend will refuse to boot without it.
#   This is the default so benchmarks and dev runs produce consistent
#   extraction results matching the SprintoInvoice pipeline.
# - OCR_PROVIDER=deepseek (or auto) is opt-in for offline / local-MLX dev
#   and uses an OpenAI-compatible endpoint (yarn ocr:dev / yarn slm:dev).
#   No API key is needed for local MLX OCR.
OCR_PROVIDER=llamaparse
#OCR_PROVIDER_API_KEY=
# For Docker: OCR/SLM containers proxy to these upstream endpoints.
# Set to your local MLX server (yarn ocr:dev / yarn slm:dev) or a remote API.
OCR_REMOTE_BASE_URL=http://localhost:8200/v1
SLM_REMOTE_BASE_URL=http://localhost:8300/v1
OCR_PROVIDER_BASE_URL=http://localhost:8200/v1
OCR_MODEL=mlx-community/DeepSeek-OCR-4bit
OCR_TIMEOUT_MS=300000
OCR_MAX_TOKENS=768
#DEEPSEEK_OCR_PROMPT=<image>\n<|grounding|>Convert the document to markdown.
# Field verifier (SLM) is optional when OCR_PROVIDER=llamaparse because
# LlamaExtract emits field-level provenance natively. The backend auto-coerces
# FIELD_VERIFIER_PROVIDER to 'none' in that case when it's not set explicitly.
# Set to 'http' to force the SLM verifier (required on OCR_PROVIDER=deepseek/auto).
FIELD_VERIFIER_PROVIDER=none
FIELD_VERIFIER_BASE_URL=http://localhost:8300/v1
FIELD_VERIFIER_TIMEOUT_MS=20000
#FIELD_VERIFIER_API_KEY=

LOCAL_FILE_STORE_ROOT=.local-run/artifacts
S3_FILE_STORE_BUCKET=ledgerbuddy-local
S3_FILE_STORE_REGION=us-east-1
S3_FILE_STORE_PREFIX=ledgerbuddy
S3_FILE_STORE_ENDPOINT=http://localhost:9100
S3_FILE_STORE_PUBLIC_ENDPOINT=
S3_FILE_STORE_FORCE_PATH_STYLE=true

FOLDER_SOURCE_KEY=local-folder
FOLDER_SOURCE_PATH=./sample-invoices/inbox
FOLDER_RECURSIVE=false

MOCK_OCR_TEXT=
MOCK_OCR_CONFIDENCE=0.95

# LlamaParse cloud OCR (set OCR_PROVIDER=llamaparse to use)
#LLAMA_CLOUD_API_KEY=llx-...
LLAMA_PARSE_TIER=cost_effective
#LLAMA_PARSE_OPTIMIZE_MODE=agentic
#LLAMA_PARSE_CUSTOM_PROMPT=
LLAMA_PARSE_EXTRACT_ENABLED=true
#LLAMA_PARSE_EXTRACT_TIER=cost_effective

CONFIDENCE_EXPECTED_MAX_TOTAL=100000
CONFIDENCE_EXPECTED_MAX_DUE_DAYS=90
CONFIDENCE_AUTO_SELECT_MIN=91

TALLY_ENDPOINT=http://tally.example.local
TALLY_COMPANY=My Company Pvt Ltd
TALLY_PURCHASE_LEDGER=Purchase
TALLY_CGST_LEDGER=Input CGST
TALLY_SGST_LEDGER=Input SGST
TALLY_IGST_LEDGER=Input IGST
TALLY_CESS_LEDGER=Input Cess

DEFAULT_APPROVER=system
INVITE_EMAIL_PROVIDER=sendgrid
INVITE_SMTP_HOST=mailhog
INVITE_SMTP_PORT=1125
INVITE_SMTP_SECURE=false
INVITE_SMTP_USERNAME=
INVITE_SMTP_PASSWORD=
INVITE_SENDGRID_API_KEY=local-sendgrid-key
INVITE_SENDGRID_ENDPOINT=http://mailhog-oauth:8026/sendgrid/v3/mail/send
INVITE_SENDGRID_TIMEOUT_MS=15000
INVITE_FROM=no-reply@invoice.local
INVITE_BASE_URL=http://localhost:5177

# DEPRECATED: MAILBOX_ALERT_* vars are no longer used.
# Mailbox notifications now use INVITE_SMTP_* / INVITE_SENDGRID_* configuration above.
# These vars will be removed in the next release. Remove them from your environment.
#MAILBOX_ALERT_SMTP_HOST=
#MAILBOX_ALERT_SMTP_PORT=587
#MAILBOX_ALERT_SMTP_SECURE=false
#MAILBOX_ALERT_SMTP_USERNAME=
#MAILBOX_ALERT_SMTP_PASSWORD=
#MAILBOX_ALERT_FROM=
#MAILBOX_ALERT_TO=

# Anumati AA bank connection (leave empty to use mock)
ANUMATI_ENTITY_ID=
ANUMATI_API_KEY=
ANUMATI_JWS_PRIVATE_KEY=
ANUMATI_AES_KEY=
ANUMATI_AA_BASE_URL=
ANUMATI_WEBVIEW_URL=
ANUMATI_CALLBACK_BASE_URL=

# E2E test Keycloak settings
E2E_KEYCLOAK_BASE_URL=http://127.0.0.1:8280
E2E_KC_REALM=ledgerbuddy
E2E_OIDC_CLIENT_ID=ledgerbuddy-app
E2E_OIDC_CLIENT_SECRET=ledgerbuddy-local-secret
