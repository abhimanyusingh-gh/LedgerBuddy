{
  "name": "ledgerbuddy-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "[ -f .env ] || cp .env.example .env; ENV=${ENV:-local} tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "start": "ENV=${ENV:-local} node dist/server.js",
    "worker:once": "ENV=${ENV:-local} tsx src/scripts/runWorkerOnce.ts",
    "seed:platform-admin": "ENV=${ENV:-local} node dist/scripts/seedPlatformAdmin.js",
    "seed:demo-tenant": "ENV=${ENV:-local} tsx src/scripts/seedDemoTenant.ts",
    "test": "jest --config jest.config.cjs --runInBand --forceExit --testPathIgnorePatterns=/e2e/",
    "coverage": "jest --config jest.config.cjs --runInBand --forceExit --testPathIgnorePatterns=/e2e/ --coverage",
    "test:e2e": "jest --config jest.config.cjs --runInBand ../dev/e2e/backend/saasLifecycle.e2e.test.ts ../dev/e2e/backend/sendgridInviteFormatting.e2e.test.ts ../dev/e2e/backend/platformAdminUsage.e2e.test.ts ../dev/e2e/backend/tenantLifecycle.e2e.test.ts",
    "test:e2e:saas": "jest --config jest.config.cjs --runInBand ../dev/e2e/backend/saasLifecycle.e2e.test.ts",
    "test:e2e:email-oauth": "jest --config jest.config.cjs --runInBand ../dev/e2e/backend/emailOAuthIngestion.e2e.test.ts",
    "test:integration": "LOCALSTACK_ENDPOINT=http://localhost:4566 jest --config jest.config.cjs --runInBand --testPathPattern=\\.integration\\.test\\.ts$",
    "test:e2e:localstack": "LOCALSTACK_ENDPOINT=http://localhost:4566 jest --config jest.config.cjs --runInBand ../dev/e2e/backend/localstackDeploy.e2e.test.ts",
    "test:harness": "jest --config jest.config.cjs --runInBand --forceExit --testPathPattern=test-utils/",
    "perf:tds": "tsx scripts/perf/tdsComputeGate.ts",
    "perf:payment": "tsx scripts/perf/paymentRecordingGate.ts",
    "perf:gates": "yarn perf:tds && yarn perf:payment",
    "perf:test": "node --import tsx --test scripts/perf/perfGate.test.ts",
    "benchmark:deepseek": "tsx src/scripts/runSampleInvoiceBenchmark.ts --ocr deepseek",
    "benchmark:llamaparse": "tsx src/scripts/runSampleInvoiceBenchmark.ts --ocr llamaparse",
    "benchmark:llamaextract": "LLAMA_PARSE_EXTRACT_ENABLED=true LLAMA_PARSE_EXTRACT_TIER=agentic tsx src/scripts/runSampleInvoiceBenchmark.ts --ocr llamaparse",
    "benchmark:llamaparse:dump": "tsx src/scripts/runSampleInvoiceBenchmark.ts --ocr llamaparse --dump-only",
    "benchmark:llamaparse:generate-spec": "tsx src/scripts/runSampleInvoiceBenchmark.ts --ocr llamaparse --dump-only --generate-spec",
    "benchmark:llamaparse:generate-spec:new": "tsx src/scripts/runSampleInvoiceBenchmark.ts --ocr llamaparse --dump-only --generate-spec --file-prefix DV- --file-prefix FC-",
    "bake:demo-fixtures": "tsx src/scripts/bakeDemoFixtures.ts",
    "check:contract": "tsx scripts/check-fe-be-contract.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1030.0",
    "@aws-sdk/s3-request-presigner": "^3.1030.0",
    "@llamaindex/llama-cloud": "latest",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "axios": "^1.15.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "form-data": "^4.0.5",
    "imapflow": "^1.3.1",
    "ioredis": "^5.10.1",
    "mailparser": "^3.9.8",
    "mongoose": "^8.9.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@testcontainers/mongodb": "^10.13.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^7.0.11",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.9",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2"
  }
}
