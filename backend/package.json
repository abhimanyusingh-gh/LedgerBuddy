{
  "name": "billforge-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "[ -f .env ] || cp .env.example .env; ENV=${ENV:-local} tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "ENV=${ENV:-local} node dist/server.js",
    "worker:once": "ENV=${ENV:-local} tsx src/scripts/runWorkerOnce.ts",
    "seed:platform-admin": "ENV=${ENV:-local} node dist/scripts/seedPlatformAdmin.js",
    "test": "jest --config jest.config.cjs --runInBand --forceExit --testPathIgnorePatterns=/src/e2e/",
    "coverage": "jest --config jest.config.cjs --runInBand --forceExit --testPathIgnorePatterns=/src/e2e/ --coverage",
    "test:e2e": "jest --config jest.config.cjs --runInBand src/e2e/folderIngestion.e2e.test.ts src/e2e/saasLifecycle.e2e.test.ts src/e2e/sendgridInviteFormatting.e2e.test.ts src/e2e/platformAdminUsage.e2e.test.ts src/e2e/tenantLifecycle.e2e.test.ts src/e2e/emailVerification.e2e.test.ts",
    "test:e2e:saas": "jest --config jest.config.cjs --runInBand src/e2e/saasLifecycle.e2e.test.ts",
    "test:e2e:email-oauth": "jest --config jest.config.cjs --runInBand src/e2e/emailOAuthIngestion.e2e.test.ts",
    "test:integration": "LOCALSTACK_ENDPOINT=http://localhost:4566 jest --config jest.config.cjs --runInBand --testPathPattern=\\.integration\\.test\\.ts$",
    "test:e2e:localstack": "LOCALSTACK_ENDPOINT=http://localhost:4566 jest --config jest.config.cjs --runInBand src/e2e/localstackDeploy.e2e.test.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.893.0",
    "@llamaindex/llama-cloud": "latest",
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "form-data": "^4.0.5",
    "imapflow": "^1.0.181",
    "mailparser": "^3.7.2",
    "mongoose": "^8.9.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.1",
    "sharp": "^0.34.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^7.0.11",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
