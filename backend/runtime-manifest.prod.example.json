{
  "defaultTenantId": "tenant-default",
  "defaultWorkloadTier": "standard",
  "database": {
    "provider": "mongo",
    "uri": "mongodb://replace-with-prod-uri"
  },
  "ocr": {
    "provider": "deepseek",
    "deepseek": {
      "baseUrl": "http://invoice-ocr.modal.internal/v1",
      "model": "invoice-ocr-model",
      "timeoutMs": 3600000
    }
  },
  "verifier": {
    "provider": "http",
    "http": {
      "baseUrl": "http://invoice-slm.modal.internal/v1",
      "timeoutMs": 20000,
      "apiKey": "replace-with-token"
    }
  },
  "extraction": {
    "ocrHighConfidenceThreshold": 0.92
  },
  "sources": [
    {
      "type": "email",
      "key": "ap-inbox",
      "tenantId": "tenant-default",
      "workloadTier": "standard",
      "transport": "imap",
      "mailhogApiBaseUrl": "",
      "host": "imap.gmail.com",
      "port": 993,
      "secure": true,
      "username": "replace-with-username",
      "authMode": "oauth2",
      "password": "",
      "oauth2": {
        "clientId": "replace-with-google-client-id",
        "clientSecret": "replace-with-google-client-secret",
        "refreshToken": "replace-with-google-refresh-token",
        "accessToken": "",
        "tokenEndpoint": "https://oauth2.googleapis.com/token"
      },
      "mailbox": "INBOX",
      "fromFilter": ""
    }
  ],
  "export": {
    "tallyEndpoint": "http://tally.internal:9000",
    "tallyCompany": "My Company Pvt Ltd",
    "tallyPurchaseLedger": "Purchase"
  }
}
