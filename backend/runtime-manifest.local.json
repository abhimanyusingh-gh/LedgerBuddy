{
  "defaultTenantId": "local-demo",
  "defaultWorkloadTier": "standard",
  "database": {
    "provider": "mongo",
    "uri": "mongodb://billforge_app:billforge_local_pass@mongo:27017/billforge?authSource=billforge"
  },
  "ocr": {
    "provider": "deepseek",
    "deepseek": {
      "model": "mlx-community/DeepSeek-OCR-4bit"
    }
  },
  "verifier": {
    "provider": "http",
    "http": {}
  },
  "extraction": {
    "ocrHighConfidenceThreshold": 0.92
  },
  "sources": [
    {
      "type": "folder",
      "key": "local-folder",
      "tenantId": "local-demo",
      "workloadTier": "standard",
      "folderPath": "/app/sample-invoices/inbox",
      "recursive": false
    }
  ],
  "export": {
    "tallyEndpoint": "http://tally.example.local",
    "tallyCompany": "Demo Company",
    "tallyPurchaseLedger": "Purchase"
  }
}
