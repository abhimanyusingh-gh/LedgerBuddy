{
  "name": "billforge",
  "private": true,
  "version": "0.1.0",
  "packageManager": "yarn@4.9.2",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev:backend": "yarn workspace billforge-backend run dev",
    "dev:frontend": "yarn workspace billforge-frontend run dev",
    "dev": "yarn dev:backend & yarn dev:frontend",
    "build": "yarn workspace billforge-backend run build && yarn workspace billforge-frontend run build",
    "worker:once": "yarn workspace billforge-backend run worker:once",
    "docker:up": "bash ./scripts/docker-up.sh",
    "docker:up:claude_cli": "RESTART_LOCAL_ML=true SLM_ENGINE=local_claude_cli SLM_MULTI_STEP_EXTRACTION=true bash ./scripts/docker-up.sh",
    "docker:up:claude_cli:single": "RESTART_LOCAL_ML=true SLM_ENGINE=local_claude_cli SLM_EXTRACTION_PIPELINE=single_verify SLM_MULTI_STEP_EXTRACTION=false bash ./scripts/docker-up.sh",
    "docker:up:codex_cli": "RESTART_LOCAL_ML=true SLM_ENGINE=local_codex_cli bash ./scripts/docker-up.sh",
    "docker:up:mlx": "RESTART_LOCAL_ML=true SLM_ENGINE=local_mlx SLM_EXTRACTION_PIPELINE=single_verify SLM_MULTI_STEP_EXTRACTION=false bash ./scripts/docker-up.sh",
    "docker:up:mlx:multi": "RESTART_LOCAL_ML=true SLM_ENGINE=local_mlx SLM_MULTI_STEP_EXTRACTION=true bash ./scripts/docker-up.sh",
    "docker:down": "bash ./scripts/docker-down.sh",
    "docker:down:all": "KEEP_ML=false bash ./scripts/docker-down.sh",
    "docker:reload": "bash ./scripts/docker-reload.sh",
    "docker:restart": "bash ./scripts/docker-down.sh && bash ./scripts/docker-up.sh",
    "logs:local": "bash ./scripts/logs-local.sh",
    "ocr:dev": "PYTHON_BIN=${PYTHON_BIN:-python3}; if [ -x ./.venv-ml/bin/python ]; then PYTHON_BIN=./.venv-ml/bin/python; fi; \"$PYTHON_BIN\" -m uvicorn app.api:app --app-dir invoice-ocr --host 0.0.0.0 --port 8000",
    "slm:dev": "PYTHON_BIN=${PYTHON_BIN:-python3}; if [ -x ./.venv-ml/bin/python ]; then PYTHON_BIN=./.venv-ml/bin/python; fi; \"$PYTHON_BIN\" -m uvicorn app.api:app --app-dir invoice-slm --host 0.0.0.0 --port 8100",
    "slm:claude:multi": "SLM_ENGINE=local_claude_cli SLM_MULTI_STEP_EXTRACTION=true bash ./scripts/slm-restart.sh",
    "slm:claude:single": "SLM_ENGINE=local_claude_cli SLM_EXTRACTION_PIPELINE=single_verify SLM_MULTI_STEP_EXTRACTION=false bash ./scripts/slm-restart.sh",
    "slm:mlx:single": "SLM_ENGINE=local_mlx SLM_EXTRACTION_PIPELINE=single_verify SLM_MULTI_STEP_EXTRACTION=false bash ./scripts/slm-restart.sh",
    "slm:mlx:multi": "SLM_ENGINE=local_mlx SLM_MULTI_STEP_EXTRACTION=true bash ./scripts/slm-restart.sh",
    "pull-models": "bash ./scripts/pull-models.sh",
    "benchmark:ml": "bash ./scripts/benchmark-ml.sh",
    "test": "yarn workspace billforge-backend run test && yarn workspace billforge-frontend run test",
    "coverage:check": "yarn workspace billforge-backend run coverage && yarn workspace billforge-frontend run coverage",
    "knip": "knip --workspace backend --workspace frontend",
    "quality:check": "yarn run knip && yarn run coverage:check",
    "prepare": "husky",
    "e2e:local": "bash ./scripts/e2e-local.sh",
    "e2e:email-oauth": "bash ./scripts/e2e-email-oauth.sh",
    "e2e:frontend": "yarn workspace billforge-frontend run test:e2e",
    "e2e:frontend:local": "bash ./scripts/e2e-frontend.sh"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "knip": "^5.66.1"
  }
}
