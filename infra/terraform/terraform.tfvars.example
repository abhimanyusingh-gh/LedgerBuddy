aws_region   = "us-east-1"
project_name = "ledgerbuddy"
environment  = "stg"

vpc_id     = "vpc-xxxxxxxx"
subnet_ids = ["subnet-aaaaaaa", "subnet-bbbbbbb"]

instance_type = "t3.small"
worker_market_type = "spot"
app_image     = "123456789012.dkr.ecr.us-east-1.amazonaws.com/ledgerbuddy-backend:latest"

provision_artifact_bucket      = true
artifact_bucket_name           = "ledgerbuddy-prod-artifacts-example"
artifact_bucket_prefix         = "invoice-artifacts"
artifact_bucket_force_destroy  = false
artifact_bucket_versioning_enabled = true
artifact_bucket_expiration_days    = 0

provision_documentdb = true

# When provision_documentdb=true, mongo_uri is ignored and Terraform injects
# the generated DocumentDB URI into worker runtime.
mongo_uri = ""
documentdb_allowed_cidrs = ["10.0.0.0/16"]
documentdb_master_username = "invoice_admin"
documentdb_master_password = "replace-with-strong-password"
documentdb_db_name         = "ledgerbuddy"
documentdb_engine_version  = "5.0.0"
documentdb_instance_class  = "db.t3.medium"
documentdb_instance_count  = 1
documentdb_backup_retention_period = 7
documentdb_preferred_backup_window = "07:00-09:00"
documentdb_storage_encrypted       = true
documentdb_deletion_protection     = true
documentdb_skip_final_snapshot     = false
documentdb_apply_immediately       = true

ingestion_sources = "email"
email_source_key  = "ap-inbox"
email_host        = "imap.gmail.com"
email_port        = 993
email_secure      = true
email_username    = "ap-team@example.com"
email_password    = "replace-with-app-password"
email_mailbox     = "INBOX"
email_from_filter = ""

ocr_provider = "deepseek"

tally_endpoint = "http://tally.internal:9000"
tally_company  = "My Company Pvt Ltd"
tally_purchase_ledger = "Purchase"

schedule_scale_up_cron   = "0 1 * * *"
schedule_scale_down_cron = "30 1 * * *"

api_ingress_cidrs = ["10.0.0.0/16"]

extra_env = {
  PORT               = "4000"
  OCR_PROVIDER_BASE_URL  = "http://your-invoice-ocr-endpoint:8000/v1"
  OCR_MODEL = "deepseek-ai/DeepSeek-OCR"
  FIELD_VERIFIER_BASE_URL = "http://your-invoice-slm-endpoint:8100/v1"
  # OCR_PROVIDER_API_KEY = "set-only-if-endpoint-requires-auth"
}

# Optional composable app manifest override block.
# Reuse worker/documentdb/IAM modules for future apps by replacing values here.
app_manifest = {
  ingestion_sources = "email"
  ocr_provider      = "deepseek"
  env = {
    DEFAULT_TENANT_ID = "tenant-default"
  }
}

# STS IAM role wiring (used only in stg/prod)
sts_trusted_services = ["ecs-tasks.amazonaws.com"]
sts_assume_role_arns = [
  "arn:aws:iam::123456789012:role/platform-sts-issuer"
]
